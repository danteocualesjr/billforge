{
  "name": "billforge",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @billforge/api & npm run dev --workspace @billforge/dashboard",
    "dev:api": "npm run dev --workspace @billforge/api",
    "dev:dashboard": "npm run dev --workspace @billforge/dashboard",
    "build": "npm run build --workspaces --if-present",
    "seed": "npm run seed --workspace @billforge/api",
    "test": "npm run test --workspace @billforge/billing-core"
  }
}
